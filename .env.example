# Copy to ".env" on the droplet and fill in real values. Do NOT commit the real .env.
# The systemd unit loads this file via EnvironmentFile.

SLACK_BOT_TOKEN=xoxb-...        # Bot User OAuth Token
SLACK_APP_TOKEN=xapp-...        # App-Level Token (connections:write)
DATABASE_URL=postgresql://postgres.<ref>:<pwd>@<host>.pooler.supabase.com:6543/postgres   # optional; enables DB + alerts
